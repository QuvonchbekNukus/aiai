APP_ENV=development
BASE_DIR=.
FFMPEG_BIN=ffmpeg
OUTPUT_DIR=./output
DATA_DIR=./data
DEFAULT_VIDEO_WIDTH=1080
DEFAULT_VIDEO_HEIGHT=1920
DEFAULT_FPS=30
DEFAULT_VIDEO_CRF=18
DEFAULT_VIDEO_BITRATE=8M
DEFAULT_AUDIO_BITRATE=192k
DEFAULT_LANGUAGE=en
ENABLE_MOCK_UPLOAD=true
ENABLE_MOCK_IMAGE_GENERATION=true
ENABLE_MOCK_TTS=true
SCRIPT_PROVIDER=auto
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_TIMEOUT_SECONDS=90
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_TIMEOUT_SECONDS=90
PIPER_BIN=piper
PIPER_MODEL_PATH=
PIPER_SPEAKER=
WINDOWS_TTS_RATE=-1
SUBTITLE_FONTSIZE=30
SUBTITLE_MARGIN_V=120
BACKGROUND_MUSIC_PATH=
BACKGROUND_MUSIC_VOLUME=0.08
SCHEDULER_TIMEZONE=UTC
SCHEDULER_AUTOSTART=false
